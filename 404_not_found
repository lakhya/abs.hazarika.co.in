<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>404 - Page Not Found</title><style>body{margin:0;font-family:Arial,sans-serif;height:100vh;display:flex;justify-content:center;align-items:center;background:linear-gradient(135deg,#0169CC,#0b3c7a);color:#fff;overflow:hidden}#matrixCanvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;opacity:0;z-index:1;transition:opacity 1s ease}.container{text-align:center;animation:fade 1.5s ease;z-index:2}h1{font-size:clamp(80px,15vw,180px);margin:0;letter-spacing:5px}h2{margin-top:-10px;font-size:clamp(20px,3vw,32px);opacity:.9}p{opacity:.8;margin-top:10px}.btn{display:inline-block;margin-top:25px;padding:14px 30px;background:#fff;color:#0169CC;font-weight:700;border-radius:30px;text-decoration:none;transition:.3s;border:none;outline:none;cursor:pointer}.btn:hover{transform:scale(1.1);box-shadow:0 10px 30px rgba(0,0,0,.3)}@keyframes fade{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}.circle{position:absolute;border-radius:50%;background:rgba(255,255,255,.08);pointer-events:none}.circle:nth-child(1){width:120px;height:120px;left:10%;top:20%}.circle:nth-child(2){width:200px;height:200px;right:10%;top:60%;animation-duration:14s}.circle:nth-child(3){width:80px;height:80px;left:70%;top:10%;animation-duration:12s}@keyframes float{0%{transform:translateY(0)}50%{transform:translateY(-30px)}100%{transform:translateY(0)}}.pageExit{animation:pageExit .8s forwards ease-in}@keyframes pageExit{0%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(-120px)}}.pageReturn{animation:pageReturn 1s forwards ease-out}@keyframes pageReturn{0%{opacity:0;transform:translateY(120px)}100%{opacity:1;transform:translateY(0)}}</style></head><body><canvas id="matrixCanvas"></canvas><div class="circle"></div><div class="circle"></div><div class="container"><h1>404</h1><h2>Page Not Found</h2><p>Oops! The page you're looking for seems to have disappeared.</p><a href="#" class="btn" onclick="startMatrix(event)">Home</a></div><script>const canvas=document.getElementById("matrixCanvas"),ctx=canvas.getContext("2d");let fontSize=13,columns,drops=[];function initMatrix(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;columns=Math.floor(canvas.width/fontSize);drops=[];for(let x=0;x<columns;x++)drops[x]=Math.random()*-20}initMatrix();function drawMatrix(){ctx.fillStyle="rgba(1,105,204,0.08)";ctx.fillRect(0,0,canvas.width,canvas.height);ctx.fillStyle="#ffffff";ctx.font=fontSize+"px monospace";for(let i=0;i<drops.length;i++){ctx.fillText("404",i*fontSize,drops[i]*fontSize);if(drops[i]*fontSize>canvas.height&&Math.random()>.975)drops[i]=0;drops[i]++}}let matrixInterval;function startMatrix(e){e.preventDefault();const btn=document.querySelector(".btn"),container=document.querySelector(".container"),circles=document.querySelectorAll(".circle");container.classList.remove("pageReturn","pageExit");circles.forEach(el=>{el.classList.remove("pageReturn","pageExit")});void container.offsetWidth;btn.style.pointerEvents="none";canvas.style.opacity="1";matrixInterval=setInterval(drawMatrix,33);container.classList.add("pageExit");circles.forEach(el=>el.classList.add("pageExit"));setTimeout(()=>{clearInterval(matrixInterval);canvas.style.opacity="0"},6e3);setTimeout(()=>{container.classList.remove("pageExit");container.classList.add("pageReturn");circles.forEach(el=>{el.classList.remove("pageExit");el.classList.add("pageReturn")});btn.style.pointerEvents="auto"},6050)}window.addEventListener("resize",()=>{initMatrix()});</script></body></html>
